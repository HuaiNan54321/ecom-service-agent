# OpenAI API Key
OPENAI_API_KEY=sk-xxx

# API 代理地址（可选，默认为 OpenAI 官方地址）
OPENAI_BASE_URL=https://api.openai.com/v1

# 模型配置
MODEL_NAME=gpt-4o-mini
TEMPERATURE=0.7

# MCP 配置（第4期）
MCP_ENABLED=false
MCP_SERVER_URL=http://127.0.0.1:9123/mcp

# RAG 配置（第5期）
EMBEDDING_MODEL=text-embedding-3-small
KB_DIR=knowledge
# 向量后端：numpy（手写余弦，教学透明）/ chroma（向量数据库，生产代表）
RAG_BACKEND=numpy
# NumpyBackend 索引文件
KB_INDEX_PATH=sessions/kb_index.json
# ChromaBackend 持久化目录 + collection
CHROMA_PERSIST_DIR=sessions/chroma
CHROMA_COLLECTION=ecom_kb
